PROJECT_DIR= # Path to /ai-assistant
BRIEFBOT_LLM_PROVIDER= # LLM Provider
BRIEFBOT_LLM_MODEL= # Model
BRIEFBOT_BRIEF_DIR= # Optional for setting up other repo
BRIEFBOT_TELEGRAM_TARGET= # Optional for Telegram messaging
BRIEFBOT_GREETING_NAME= # Telegram Greeting name
BRIEFBOT_DB_PATH=data/briefbot.db
BRIEFBOT_CACHE_DIR=data/article_cache
BRIEFBOT_SUMMARY_DIR=data/summaries
BRIEFBOT_BRIEF_DIR=data/briefs
BRIEFBOT_MODEL_FOR_SUMMARIES= # Model for summaries
BRIEFBOT_ENABLE_EXEC_SUMMARY=true
BRIEFBOT_MAX_CHARS_PER_ARTICLE=12000 # Read first N chars for summary
BRIEFBOT_N_TOP_LINKS_TO_SUMMARIZE=10
BRIEFBOT_N_TRENDS_TO_SUMMARIZE=5
BRIEFBOT_DIGEST_DIR=data/daily_digest
BRIEFBOT_LOG_DIR=data/logs
BRIEFBOT_ENV_FILE=.env
BRIEFBOT_GREETING_NAME=there
BRIEFBOT_DATA_DIR= # Path to /ai-assistant/data

VITE_APP_BASE=/briefs/
VITE_API_BASE_URL=http://localhost:8000 # Backend
VITE_ALLOWED_HOSTS= # Localhost or other URLs 

DASHBOARD_BRIEFS_URL= # Location of briefs page

# Set one or both depending on provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
